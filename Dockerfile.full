# 基于 OpenClaw 中文版底包
FROM ghcr.io/1186258278/openclaw-zh:latest

# 使用 root 用户安装依赖
USER root

# OpenClaw 运行优化
ENV NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
ENV OPENCLAW_NO_RESPAWN=1

# Chromium 路径显式声明
# 底包已经装了 chromium，这里只是补充环境变量
ENV CHROME_BIN=/usr/bin/chromium
ENV CHROMIUM_PATH=/usr/bin/chromium

# 创建编译缓存目录
RUN mkdir -p /var/tmp/openclaw-compile-cache

# 安装全功能版依赖
# 说明：
# - ffmpeg：音频/视频处理
# - python3/python3-pip：Python 技能和语音工具
# - poppler-utils：PDF 技能
# - libglib2.0-0：截图/多媒体类依赖
# - 以下 lib*：Chromium 在无头模式下常见依赖
# - 中文字体与 emoji 字体用于网页渲染和截图
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    python3 \
    python3-pip \
    poppler-utils \
    libglib2.0-0 \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libxshmfence1 \
    xdg-utils \
    fonts-noto-cjk \
    fonts-noto-color-emoji \
    fonts-wqy-zenhei \
    jq \
    qrencode \
    && rm -rf /var/lib/apt/lists/*

# 安装全功能版 Python 组件
# openai-whisper：官方本地 Whisper
# faster-whisper：更轻量的本地 STT
# edge-tts：轻量 TTS
RUN python3 -m pip install --break-system-packages --no-cache-dir --upgrade pip setuptools wheel \
    && python3 -m pip install --break-system-packages --no-cache-dir \
    openai-whisper \
    faster-whisper \
    edge-tts

RUN npm install -g clawhub

# 刷新字体缓存
RUN fc-cache -fv
